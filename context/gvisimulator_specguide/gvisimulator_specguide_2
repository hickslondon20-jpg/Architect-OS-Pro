      severity: "RED",  
      label: "Culture Risk",  
      message: "You're hiring faster than 10% per quarter—culture and onboarding will strain"  
    });  
  }  
    
  *// Check burnout risk*  
  if (implied\_agi\_per\_fte\_no\_hiring \> 240000) {  
    alerts.push({  
      severity: "RED",  
      label: "Burnout Risk",  
      message: \`If you miss hiring targets, AGI/FTE reaches $${(implied\_agi\_per\_fte\_no\_hiring/1000).toFixed(0)}K—well above sustainable range\`  
    });  
  }  
    
  if (alerts.length \=== 0) {  
    return {  
      severity: "GREEN",  
      label: "Manageable Growth",  
      message: "Hiring pace and efficiency targets are within healthy operational ranges"  
    };  
  }  
    
  return alerts\[0\]; *// Return most severe*

}

