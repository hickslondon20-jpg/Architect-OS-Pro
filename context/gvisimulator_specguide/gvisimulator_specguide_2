      message: "Profit is growing slower than revenue—margin pressure from scaling costs"  
    };  
  } else {  
    return {  
      severity: "GREEN",  
      label: "Healthy Economics",  
      message: "Profit grows proportionally with revenue—economics remain sound"  
    };  
  }

}

