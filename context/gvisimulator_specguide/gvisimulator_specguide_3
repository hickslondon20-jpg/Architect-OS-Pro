Tier Gating Implementation  
Free Tier Limits (Tab 1\)  
typescript  
// Check remaining credits before calculation  
async function checkCalculationCredits(userId: string) {  
  const today \= new Date().toISOString().split('T')\[0\];  
    
  const { count } \= await supabase  
    .from('growth\_calculations')  
    .select('\*', { count: 'exact', head: true })  
    .eq('user\_id', userId)  
    .gte('created\_at', \`${today}T00:00:00Z\`)  
    .lte('created\_at', \`${today}T23:59:59Z\`);  
      
  const creditsUsed \= count || 0;  
  const creditsRemaining \= Math.max(0, 3 \- creditsUsed);  
    
  return {  
    hasCredits: creditsRemaining \> 0,  
    creditsRemaining  
  };  
}

// In component  
const handleCalculate \= async () \=\> {  
  const userTier \= getUserTier(); // From context  
    
  if (userTier \=== 'free') {  
    const { hasCredits, creditsRemaining } \= await checkCalculationCredits(userId);  
      
    if (\!hasCredits) {  
      showUpgradeModal('You've used all 3 calculations today. Upgrade to Pro for unlimited access.');  
      return;  
    }  
      
    // Show remaining credits after calculation  
    setCreditsRemaining(creditsRemaining \- 1);  
  }  
    
  // Proceed with calculation  
  await runCalculation();  
};

