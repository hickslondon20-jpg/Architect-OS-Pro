State Management Strategy  
Tab 1: Simple Component State  
typescript  
// Tab1StandardCalculator.tsx

const \[baselineInputs, setBaselineInputs\] \= useState\<BaselineInputs | null\>(null);  
const \[targetInputs, setTargetInputs\] \= useState({ revenue: '', timeframe: 12 });  
const \[calculationResult, setCalculationResult\] \= useState\<CalculationResult | null\>(null);  
const \[isCalculating, setIsCalculating\] \= useState(false);  
const \[synthesisText, setSynthesisText\] \= useState\<string | null\>(null);  
const \[isGeneratingSynthesis, setIsGeneratingSynthesis\] \= useState(false);

// Fetch Agency Snapshot on mount  
useEffect(() \=\> {  
  fetchAgencySnapshot().then(snapshot \=\> {  
    if (snapshot) {  
      setBaselineInputs({  
        baseline\_revenue: snapshot.monthly\_revenue \* 12,  
        baseline\_team\_size: snapshot.team\_size\_fte,  
        baseline\_client\_count: snapshot.active\_client\_count,  
        baseline\_retention\_rate: snapshot.retention\_rate,  
        baseline\_profit\_margin: snapshot.operating\_profit\_pct / 100,  
        baseline\_acv: snapshot.monthly\_revenue \* 12 / snapshot.active\_client\_count,  
        baseline\_agi\_per\_fte: snapshot.agi\_per\_fte  
      });  
    }  
  });  
}, \[\]);

Tab 2: Real-Time Calculation State  
typescript  
// Tab2ScenarioBuilder.tsx

const \[baselineInputs, setBaselineInputs\] \= useState\<BaselineInputs | null\>(null);  
const \[scenarioAdjustments, setScenarioAdjustments\] \= useState\<ScenarioAdjustments\>({  
  growth\_adjustment\_pct: 0,  
  acv\_adjustment\_pct: 0,  
  efficiency\_adjustment\_pct: 0,  
  retention\_adjustment\_pct: 0,  
  margin\_adjustment\_pct: 0  
});  
const \[impactMetrics, setImpactMetrics\] \= useState\<ImpactMetrics | null\>(null);  
const \[savedScenarios, setSavedScenarios\] \= useState\<SavedScenario\[\]\>(\[\]);  
const \[selectedForComparison, setSelectedForComparison\] \= useState\<string\[\]\>(\[\]);

// Real-time calculation on adjustment change  
const debouncedCalculate \= useMemo(  
  () \=\> debounce((adjustments: ScenarioAdjustments) \=\> {  
    if (\!baselineInputs) return;  
      
    const results \= runCalculationEngine({  
      baseline: baselineInputs,  
      target: {  
        revenue: baselineInputs.baseline\_revenue \* (1 \+ adjustments.growth\_adjustment\_pct),  
        timeframe\_months: 12 // Default  
      },  
      adjustments  
    });  
      
    setImpactMetrics({  
      target\_revenue: results.output\_target\_revenue,  
      target\_team\_size: results.output\_target\_team\_size,  
      target\_profit: results.output\_target\_profit,  
      target\_client\_count: results.output\_target\_client\_count,  
      monthly\_sales\_velocity: results.output\_monthly\_velocity  
    });  
  }, 300),  
  \[baselineInputs\]  
);

// Trigger recalculation on adjustment change  
useEffect(() \=\> {  
  debouncedCalculate(scenarioAdjustments);  
}, \[scenarioAdjustments, debouncedCalculate\]);

API Integration Points  
1\. Fetch Agency Snapshot  
typescript  
async function fetchAgencySnapshot(userId: string, agencyId: string) {  
  const { data, error } \= await supabase  
    .from('vi\_monthly\_kpis\_current')  
    .select('\*')  
    .eq('user\_id', userId)  
    .eq('agency\_id', agencyId)  
    .single();  
      
  if (error || \!data) return null;  
    
  return data;  
}

2\. Store Calculation  
typescript  
async function storeCalculation(inputs: CalculationInputs, results: CalculationOutputs) {  
  const { data, error } \= await supabase  
    .from('growth\_calculations')  
    .insert({  
      user\_id: getCurrentUserId(),  
      agency\_id: getCurrentAgencyId(),  
        
      // Baseline inputs  
      baseline\_revenue: inputs.baseline.revenue,  
      baseline\_team\_size: inputs.baseline.teamSize,  
      baseline\_client\_count: inputs.baseline.clientCount,  
      baseline\_retention\_rate: inputs.baseline.retentionRate,  
      baseline\_profit\_margin: inputs.baseline.profitMargin,  
      baseline\_acv: inputs.baseline.acv,  
      baseline\_agi\_per\_fte: inputs.baseline.agiPerFTE,  
        
      // Target  
