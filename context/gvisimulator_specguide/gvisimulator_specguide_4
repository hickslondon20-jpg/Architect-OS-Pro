API Route: /api/growth-velocity-synthesis  
typescript// app/api/growth-velocity-synthesis/route.ts

import { createClient } from '@supabase/supabase-js';  
import Anthropic from '@anthropic-ai/sdk';

export async function POST(request: Request) {  
  const payload: GPTSynthesisRequest \= await request.json();  
    
  // 1\. Check if synthesis already exists (caching)  
  if (payload.calculation?.calculation\_id) {  
    const cached \= await checkCachedSynthesis(payload.calculation.calculation\_id);  
    if (cached) {  
      return Response.json({ synthesis: cached, cached: true });  
    }  
  }  
    
  // 2\. Gather additional context from Project Knowledge  
  const projectContext \= await fetchProjectKnowledge(\[  
    'AE Ladder frameworks',  
    'Growth Mastery principles',  
    'Healthy agency benchmarks'  
  \]);  
    
  // 3\. Build prompt  
  const prompt \= payload.mode \=== 'single'   
    ? buildSingleScenarioPrompt(payload, projectContext)  
    : buildComparativePrompt(payload, projectContext);  
    
  // 4\. Call Anthropic API  
  const anthropic \= new Anthropic({  
    apiKey: process.env.ANTHROPIC\_API\_KEY,  
  });  
    
  const message \= await anthropic.messages.create({  
    model: 'claude-sonnet-4-20250514',  
    max\_tokens: 2000,  
    temperature: 0.7,  
    system: \`You are a strategic business advisor for marketing agency founders. You provide direct, contextual, non-prescriptive insights based on their actual business data. You never use generic advice or fail to reference their specific context.\`,  
    messages: \[{  
      role: 'user',  
      content: prompt  
    }\]  
  });  
    
  const synthesis \= message.content\[0\].type \=== 'text'   
    ? message.content\[0\].text   
    : '';  
    
  // 5\. Cache synthesis in database  
  if (payload.calculation?.calculation\_id) {  
    await cacheSynthesis(payload.calculation.calculation\_id, synthesis);  
  }  
    
  // 6\. Return synthesis  
  return Response.json({   
    synthesis,   
    cached: false,  
    tokens\_used: message.usage.output\_tokens  
  });  
}

