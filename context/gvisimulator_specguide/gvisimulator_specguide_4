Prompt Variable Injection  
Template Processing Function  
typescriptfunction injectPromptVariables(  
  template: string,  
  data: GPTSynthesisRequest  
): string {  
  let prompt \= template;  
    
  // Replace simple variables  
  Object.entries(data.snapshot\_context).forEach((\[key, value\]) \=\> {  
    const regex \= new RegExp(\`\\\\{snapshot\_context\\\\.${key}\\\\}\`, 'g');  
    prompt \= prompt.replace(regex, String(value || 'Not specified'));  
  });  
    
  // Replace calculation variables  
  if (data.calculation) {  
    Object.entries(data.calculation.baseline\_inputs).forEach((\[key, value\]) \=\> {  
      const regex \= new RegExp(\`\\\\{calculation\\\\.baseline\_inputs\\\\.${key}\\\\}\`, 'g');  
      prompt \= prompt.replace(regex, String(value));  
    });  
      
    Object.entries(data.calculation.output\_deltas).forEach((\[key, value\]) \=\> {  
      const regex \= new RegExp(\`\\\\{calculation\\\\.output\_deltas\\\\.${key}\\\\}\`, 'g');  
      prompt \= prompt.replace(regex, String(value));  
    });  
  }  
    
  // Handle complex injections (arrays, objects)  
  // Pressure alerts  
  if (data.calculation?.pressure\_alerts) {  
    const alertsList \= Object.entries(data.calculation.pressure\_alerts)  
      .map((\[family, alert\]) \=\> \`- ${family}: \[${alert.severity}\] ${alert.message}\`)  
      .join('\\n');  
    prompt \= prompt.replace(/\\{pressure\_alerts\_list\\}/g, alertsList);  
  }  
    
  return prompt;  
}

