typescript// For better UX, stream GPT response in real-time

async function streamSynthesis(payload: GPTSynthesisRequest): Promise\<ReadableStream\> {  
  const anthropic \= new Anthropic({ apiKey: process.env.ANTHROPIC\_API\_KEY });  
    
  const stream \= await anthropic.messages.stream({  
    model: 'claude-sonnet-4-20250514',  
    max\_tokens: 2000,  
    messages: \[{ role: 'user', content: buildPrompt(payload) }\]  
  });  
    
  return new ReadableStream({  
    async start(controller) {  
      for await (const chunk of stream) {  
        if (chunk.type \=== 'content\_block\_delta' && chunk.delta.type \=== 'text\_delta') {  
          controller.enqueue(new TextEncoder().encode(chunk.delta.text));  
        }  
      }  
      controller.close();  
    }  
  });  
}

