Quality Assurance: GPT Output Validation  
Post-Processing Checks  
typescriptfunction validateGPTSynthesis(synthesis: string): ValidationResult {  
  const issues: string\[\] \= \[\];  
    
  // Check 1: Contains required sections  
  const requiredSections \= \['Reality Check', 'Capacity Warning', 'One Big Lever', 'Watch-Outs'\];  
  for (const section of requiredSections) {  
    if (\!synthesis.includes(section)) {  
      issues.push(\`Missing section: ${section}\`);  
    }  
  }  
    
  // Check 2: Not too short (probable error)  
  if (synthesis.length \< 200\) {  
    issues.push('Synthesis suspiciously short \- may be incomplete');  
  }  
    
  // Check 3: Not too long (exceeded token limit?)  
  if (synthesis.length \> 3000\) {  
    issues.push('Synthesis exceeds recommended length');  
  }  
    
  // Check 4: Contains forbidden phrases (generic advice)  
  const forbiddenPhrases \= \[  
    'you may want to consider',  
    'it might be worth',  
    'generally speaking',  
    'in most cases',  
    'typically agencies'  
  \];  
    
  for (const phrase of forbiddenPhrases) {  
    if (synthesis.toLowerCase().includes(phrase)) {  
      issues.push(\`Contains generic phrase: "${phrase}"\`);  
    }  
  }  
    
  // Check 5: References user's actual context  
  const requiredContextReferences \= \[  
    'referral', 'outbound', 'paid', // Sales motion  
    'delivery', 'capacity', // Operations  
    'retention', 'margin' // Metrics  
  \];  
    
  const hasContextReferences \= requiredContextReferences.some(term \=\>  
    synthesis.toLowerCase().includes(term)  
  );  
    
  if (\!hasContextReferences) {  
    issues.push('Does not reference specific user context');  
  }  
    
  return {  
    isValid: issues.length \=== 0,  
    issues,  
    shouldRetry: issues.length \> 2 // Retry if multiple issues  
  };  
}

// Usage in API  
