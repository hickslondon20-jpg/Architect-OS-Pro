Frontend Display Component  
typescript// components/GPTSynthesisDisplay.tsx

interface GPTSynthesisDisplayProps {  
  calculationId: string;  
  mode: 'single' | 'comparative';  
  onComplete?: () \=\> void;  
}

export function GPTSynthesisDisplay({ calculationId, mode, onComplete }: GPTSynthesisDisplayProps) {  
  const \[synthesis, setSynthesis\] \= useState\<string | null\>(null);  
  const \[isLoading, setIsLoading\] \= useState(true);  
  const \[error, setError\] \= useState\<string | null\>(null);  
    
  useEffect(() \=\> {  
    generateSynthesis();  
  }, \[calculationId\]);  
    
  async function generateSynthesis() {  
    setIsLoading(true);  
      
    try {  
      // Gather all required data  
      const calculation \= await fetchCalculation(calculationId);  
      const snapshotContext \= await fetchSnapshotContext();  
        
      // Call synthesis API  
      const response \= await fetch('/api/growth-velocity-synthesis', {  
        method: 'POST',  
        headers: { 'Content-Type': 'application/json' },  
        body: JSON.stringify({  
          mode,  
          calculation,  
          snapshot\_context: snapshotContext,  
          benchmarks: STANDARD\_BENCHMARKS  
        })  
      });  
        
      const { synthesis: text, cached } \= await response.json();  
        
      setSynthesis(text);  
      setIsLoading(false);  
        
      if (onComplete) onComplete();  
        
    } catch (err) {  
      setError('Failed to generate synthesis. Please try again.');  
      setIsLoading(false);  
    }  
  }  
    
  if (isLoading) {  
    return (  
      \<div className="synthesis-loading"\>  
        \<Spinner /\>  
        \<p\>Analyzing your growth scenario...\</p\>  
      \</div\>  
    );  
  }  
    
  if (error) {  
    return (  
      \<div className="synthesis-error"\>  
        \<AlertCircle /\>  
        \<p\>{error}\</p\>  
        \<Button onClick={generateSynthesis}\>Retry\</Button\>  
      \</div\>  
    );  
  }  
    
  return (  
    \<div className="synthesis-display"\>  
      \<SynthesisHeader mode={mode} /\>  
      \<SynthesisContent text={synthesis} /\>  
    \</div\>  
  );  
}

Synthesis Content Parser  
typescript// Parse synthesis into structured sections

function parseSynthesisContent(text: string): SynthesisSection\[\] {  
  const sections: SynthesisSection\[\] \= \[\];  
    
  // Split by section headers (\#\# Section X:)  
  const sectionRegex \= /\#\# Section \\d+: (.+?)\\n(\[\\s\\S\]+?)(?=\#\# Section \\d+:|$)/g;  
  let match;  
    
  while ((match \= sectionRegex.exec(text)) \!== null) {  
    sections.push({  
      title: match\[1\].trim(),  
      content: match\[2\].trim()  
    });  
  }  
    
  return sections;  
}

// Display component  
function SynthesisContent({ text }: { text: string }) {  
  const sections \= parseSynthesisContent(text);  
    
  return (  
    \<div className="synthesis-sections"\>  
      {sections.map((section, idx) \=\> (  
        \<div key={idx} className="synthesis-section"\>  
          \<h3 className="section-title"\>{section.title}\</h3\>  
          \<div className="section-content"\>  
            {formatSectionContent(section.content)}  
          \</div\>  
        \</div\>  
      ))}  
    \</div\>  
  );  
}

// Format content (convert bullet points, emphasis, etc.)  
function formatSectionContent(content: string): JSX.Element {  
  // Convert markdown-style bullets to HTML  
  const formatted \= content  
    .replace(/^- ⚠️/gm, '\<div class="alert-item"\>⚠️')  
    .replace(/^- /gm, '\<li\>')  
    .replace(/\\n(?\!\<)/g, '\</div\>\\n');  
    
  return \<div dangerouslySetInnerHTML={{ \_\_html: formatted }} /\>;  
}

Caching Strategy  
Cache Logic  
typescriptinterface CacheDecision {  
  shouldCache: boolean;  
  cacheKey: string;  
  ttl?: number; // Time to live in seconds  
}

function decideCaching(  
  mode: 'single' | 'comparative',  
  calculationId: string,  
  scenarioIds?: string\[\]  
): CacheDecision {  
  if (mode \=== 'single') {  
    // Single scenario: Cache permanently by calculation\_id  
    return {  
      shouldCache: true,  
      cacheKey: calculationId,  
      ttl: null // Permanent  
    };  
  } else {  
    // Comparative: Cache temporarily by scenario combination  
    const cacheKey \= scenarioIds?.sort().join('-');  
    return {  
      shouldCache: true,  
      cacheKey: \`comparison-${cacheKey}\`,  
      ttl: 3600 \* 24 \* 7 // 7 days  
    };  
  }  
}

