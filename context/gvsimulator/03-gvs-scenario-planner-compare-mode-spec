### 1.3 Create `gvs_saved_comparisons` (Saved Comparisons Table)

Explicit saves only. One record per named comparison. Fully reloadable without recomputation.

```sql
CREATE TABLE public.gvs_saved_comparisons (
  id                      uuid NOT NULL DEFAULT gen_random_uuid(),
  user_id                 uuid NOT NULL,
  agency_id               uuid NOT NULL,
  runtime_comparison_id   uuid NULL,
  comparison_name         text NOT NULL,
  scenario_ids            jsonb NOT NULL,
  scenario_snapshots      jsonb NOT NULL,
  baseline_snapshot       jsonb NOT NULL,
  deterministic_output    jsonb NOT NULL,
  synthesis_content       jsonb NULL,
  version                 integer NOT NULL DEFAULT 1,
  created_at              timestamp with time zone NULL DEFAULT now(),
  updated_at              timestamp with time zone NULL DEFAULT now(),
  CONSTRAINT gvs_saved_comparisons_pkey PRIMARY KEY (id),
  CONSTRAINT gvs_saved_comparisons_agency_fkey
    FOREIGN KEY (agency_id) REFERENCES agencies (agency_id) ON DELETE CASCADE,
  CONSTRAINT gvs_saved_comparisons_user_fkey
    FOREIGN KEY (user_id) REFERENCES auth.users (id) ON DELETE CASCADE,
  CONSTRAINT gvs_saved_comparisons_runtime_fkey
    FOREIGN KEY (runtime_comparison_id)
    REFERENCES public.gvs_comparison_runs (id) ON DELETE SET NULL
);

CREATE INDEX idx_gvs_saved_comparisons_user
  ON public.gvs_saved_comparisons USING btree (user_id);

CREATE INDEX idx_gvs_saved_comparisons_agency
  ON public.gvs_saved_comparisons USING btree (agency_id);

CREATE INDEX idx_gvs_saved_comparisons_created
  ON public.gvs_saved_comparisons USING btree (created_at DESC);

CREATE INDEX idx_gvs_saved_comparisons_runtime
  ON public.gvs_saved_comparisons USING btree (runtime_comparison_id);

-- updated_at auto-update trigger
CREATE OR REPLACE FUNCTION update_gvs_saved_comparisons_updated_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = now();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER maintain_gvs_saved_comparisons_updated_at
  BEFORE UPDATE ON gvs_saved_comparisons
  FOR EACH ROW EXECUTE FUNCTION update_gvs_saved_comparisons_updated_at();
```

