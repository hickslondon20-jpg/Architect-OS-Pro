### 1.2 Create `gvs_comparison_runs` (Runtime Comparison Table)

Every comparison execution writes a record here when the GPT call is triggered. One record per run regardless of whether it is explicitly saved.

```sql
CREATE TABLE public.gvs_comparison_runs (
  id                    uuid NOT NULL DEFAULT gen_random_uuid(),
  user_id               uuid NOT NULL,
  agency_id             uuid NOT NULL,
  scenario_ids          jsonb NOT NULL,
  scenario_ids_hash     text GENERATED ALWAYS AS (
                          encode(sha256(scenario_ids::text::bytea), 'hex')
                        ) STORED,
  scenario_snapshots    jsonb NOT NULL,
  baseline_snapshot     jsonb NOT NULL,
  deterministic_output  jsonb NULL,
  synthesis_content     jsonb NULL,
  status                text NOT NULL DEFAULT 'pending'
                          CHECK (status IN ('pending', 'processing', 'complete', 'error')),
  is_saved              boolean NOT NULL DEFAULT false,
  saved_at              timestamp with time zone NULL,
  created_at            timestamp with time zone NULL DEFAULT now(),
  CONSTRAINT gvs_comparison_runs_pkey PRIMARY KEY (id),
  CONSTRAINT gvs_comparison_runs_agency_fkey
    FOREIGN KEY (agency_id) REFERENCES agencies (agency_id),
  CONSTRAINT gvs_comparison_runs_user_fkey
    FOREIGN KEY (user_id) REFERENCES auth.users (id)
);

-- Deduplication lookup: find existing run for same scenario combination
CREATE UNIQUE INDEX idx_gvs_comparison_runs_dedup
  ON public.gvs_comparison_runs (user_id, scenario_ids_hash)
  WHERE status = 'complete';

CREATE INDEX idx_gvs_comparison_runs_user
  ON public.gvs_comparison_runs USING btree (user_id);

CREATE INDEX idx_gvs_comparison_runs_agency
  ON public.gvs_comparison_runs USING btree (agency_id);

CREATE INDEX idx_gvs_comparison_runs_status
  ON public.gvs_comparison_runs USING btree (status);

CREATE INDEX idx_gvs_comparison_runs_is_saved
  ON public.gvs_comparison_runs USING btree (is_saved);
```

