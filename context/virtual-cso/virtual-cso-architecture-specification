python  
def query\_historical\_trends(  
    user\_id: str,  
    metrics: list\[str\],  
    time\_range: str \= "last\_quarter"  
) \-\> dict:  
    """  
    Query historical data for specific metrics.  
      
    Parameters:  
    \- metrics: List of metrics to pull (e.g., \["margin", "acv", "client\_concentration"\])  
    \- time\_range: "last\_quarter" | "last\_two\_quarters" | "year"  
      
    Returns:  
    {  
        "time\_range": "string",  
        "score\_deltas": \[  
            {  
                "capability\_id": "string",  
                "capability\_name": "string",  
                "previous\_score": 0.0-1.0,  
                "current\_score": 0.0-1.0,  
                "delta": \-1.0 to 1.0,  
                "direction": "improved|declined|stable"  
            }  
        \],  
        "milestone\_completion": {  
            "total\_milestones": int,  
            "completed\_milestones": int,  
            "completion\_rate": 0.0-1.0  
        },  
        "initiative\_progress": \[  
            {  
                "initiative\_name": "string",  
                "start\_date": "ISO 8601",  
                "completion\_date": "ISO 8601 or null",  
                "was\_completed": bool  
            }  
        \]  
    }  
    """

**SQL:**

\-- Score deltas (comparing current to previous quarter)  
WITH current\_scores AS (  
    SELECT capability\_id, capability\_score\_pct  
    FROM gm\_assessment\_capability\_scores  
    WHERE assessment\_id \= (  
        SELECT assessment\_id FROM gm\_assessments   
        WHERE user\_id \= ${user\_id}   
        ORDER BY created\_at DESC LIMIT 1  
    )  
),  
previous\_scores AS (  
    SELECT capability\_id, capability\_score\_pct  
    FROM gm\_assessment\_capability\_scores  
    WHERE assessment\_id \= (  
        SELECT assessment\_id FROM gm\_assessments   
        WHERE user\_id \= ${user\_id}   
        ORDER BY created\_at DESC LIMIT 1 OFFSET 1  
    )  
)  
SELECT   
    c.capability\_name,  
    p.capability\_score\_pct as previous\_score,  
    cur.capability\_score\_pct as current\_score,  
    (cur.capability\_score\_pct \- p.capability\_score\_pct) as delta,  
    CASE   
        WHEN (cur.capability\_score\_pct \- p.capability\_score\_pct) \> 0.05 THEN 'improved'  
        WHEN (cur.capability\_score\_pct \- p.capability\_score\_pct) \< \-0.05 THEN 'declined'  
        ELSE 'stable'  
    END as direction  
FROM current\_scores cur  
LEFT JOIN previous\_scores p ON cur.capability\_id \= p.capability\_id  
LEFT JOIN gm\_capabilities c ON cur.capability\_id \= c.capability\_id;

\-- Milestone completion for specified time range  
SELECT   
    COUNT(\*) as total\_milestones,  
    SUM(CASE WHEN status \= 'completed' THEN 1 ELSE 0 END) as completed\_milestones,  
    CAST(SUM(CASE WHEN status \= 'completed' THEN 1 ELSE 0 END) AS FLOAT) / COUNT(\*) as completion\_rate  
FROM milestones  
WHERE user\_id \= ${user\_id}  
    AND created\_at \>= ${time\_range\_start};  
