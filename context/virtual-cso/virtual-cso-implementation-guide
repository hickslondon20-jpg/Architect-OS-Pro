Node 4: Function Node \- Parse & Validate JSON  
javascript// Node name: Parse and Validate

try {  
  const response \= $input.item.json.choices\[0\].message.content;  
    
  // Parse JSON  
  const parsed \= JSON.parse(response);  
    
  // Validate required fields exist  
  const required \= \[  
    'classification',  
    'continuity',  
    'context\_prescription'  
  \];  
    
  const isValid \= required.every(field \=\> parsed\[field\] \!== undefined);  
    
  return {  
    json: {  
      is\_valid: isValid,  
      parsed\_response: parsed,  
      raw\_response: response,  
      validation\_error: isValid ? null : 'Missing required fields'  
    }  
  };  
    
} catch (error) {  
  return {  
    json: {  
      is\_valid: false,  
      parsed\_response: null,  
      raw\_response: $input.item.json.choices\[0\].message.content,  
      validation\_error: error.message  
    }  
  };  
}  
