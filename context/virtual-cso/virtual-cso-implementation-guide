Node 2: Assemble Final Prompt  
javascriptconst input \= $input.item.json;

// Format session history  
const history \= (input.session\_history || \[\])  
  .map(msg \=\> \`${msg.role \=== 'user' ? 'Human' : 'Assistant'}: ${msg.content}\`)  
  .join('\\n\\n');

// Format context package  
const context \= input.context\_package;  
let contextBlock \= '';

if (context?.rag\_results?.chunks) {  
  contextBlock \+= '\\n\#\# Platform Knowledge:\\n\\n';  
  context.rag\_results.chunks.forEach((chunk, i) \=\> {  
    contextBlock \+= \`\[Chunk ${i+1}\] (${chunk.content\_type}, ${chunk.stage} stage)\\n${chunk.content}\\n\\n\`;  
  });  
}

if (context?.user\_data) {  
  contextBlock \+= '\\n\#\# User Context:\\n\\n';  
  contextBlock \+= \`Stage: ${context.user\_data.stage?.stage\_label}\\n\`;  
  if (context.user\_data.scores) {  
    contextBlock \+= \`\\nCapability Scores (Top Priorities):\\n\`;  
    context.user\_data.scores.capability\_scores?.slice(0, 10).forEach(cap \=\> {  
      contextBlock \+= \`- ${cap.capability\_name}: ${(cap.capability\_score\_pct \* 100).toFixed(0)}% (${cap.capability\_band})\\n\`;  
    });  
  }  
  if (context.user\_data.goals) {  
    contextBlock \+= \`\\n12-Month Goal: $${context.user\_data.goals.horizon\_12mo?.revenue\_target?.toLocaleString()}\\n\`;  
  }  
}

if (context?.historical\_data) {  
  contextBlock \+= '\\n\#\# Recent Progress:\\n\\n';  
  if (context.historical\_data.score\_deltas) {  
    contextBlock \+= 'Score Changes:\\n';  
    context.historical\_data.score\_deltas.forEach(delta \=\> {  
      contextBlock \+= \`- ${delta.capability\_name}: ${delta.direction} (${delta.delta \> 0 ? '+' : ''}${(delta.delta \* 100).toFixed(0)}%)\\n\`;  
    });  
  }  
}

return {  
  json: {  
    system\_prompt: getAgent3SystemPrompt(), // Full system prompt from spec  
    context\_block: contextBlock,  
    history\_block: history,  
    user\_message: input.user\_message,  
    thinking\_persona: input.thinking\_persona || 'strategic'  
  }  
};

function getAgent3SystemPrompt() {  
  return \`\[Full Agent 3 system prompt from specification \- behavioral principles, stage calibration, etc.\]\`;  
}  
