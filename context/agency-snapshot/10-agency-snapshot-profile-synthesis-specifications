if ((revenueModel.replacement\_revenue\_annual / economicFoundation.annual\_revenue) \> 0.30) growthTreadmillScore \+= 2;  
if ((revenueModel.replacement\_clients\_annual / revenueModel.active\_client\_count) \> 0.30) growthTreadmillScore \+= 2;  
if (economicFoundation.cash\_runway\_months \< 3\) growthTreadmillScore \+= 2;  
if (deliveryArchitecture.average\_utilization \=== "70-80%" || deliveryArchitecture.average\_utilization \=== "80%+") growthTreadmillScore \+= 1;  
if (deliveryArchitecture.founder\_time\_allocation \=== "Mostly client work" || deliveryArchitecture.founder\_time\_allocation \=== "Mix delivery-ops") growthTreadmillScore \+= 1;

// Theme 2: Cash-Margin Disconnect  
let cashMarginScore \= 0;  
if (economicFoundation.profit\_margin\_percent \> 25 && economicFoundation.cash\_runway\_months \< 2\) cashMarginScore \+= 4;  
if (economicFoundation.profit\_margin\_percent \< 15 && economicFoundation.cash\_runway\_months \> 4\) cashMarginScore \+= 3;  
if (revenueModel.revenue\_mix\_mrr\_percent \< 40 && economicFoundation.cash\_runway\_months \< 3\) cashMarginScore \+= 1;

// Theme 3: Concentration Dependency  
let concentrationScore \= 0;  
if (revenueModel.concentration\_top\_5\_percent \> 60\) concentrationScore \+= 3;  
if (economicFoundation.cash\_runway\_months \< 2\) concentrationScore \+= 2;  
if (deliveryArchitecture.founder\_time\_allocation \=== "Mostly client work" || deliveryArchitecture.founder\_time\_allocation \=== "Mix delivery-ops") concentrationScore \+= 2;  
if (revenueModel.active\_client\_count \< 20\) concentrationScore \+= 1;

// Theme 4: Service-Structure Alignment  
let alignmentScore \= 0;  
if (marketFootprint.industry\_count \<= 2 && deliveryArchitecture.team\_structure\_type \=== "Mostly generalists") alignmentScore \+= 3;  
if (revenueModel.average\_client\_value\_monthly \> 8000 && deliveryArchitecture.team\_structure\_type \=== "Mostly generalists") alignmentScore \+= 2;  
if (revenueModel.average\_client\_value\_monthly \< 2000 && deliveryArchitecture.team\_structure\_type \=== "Mostly specialists") alignmentScore \+= 2;  
if (marketFootprint.services\_offered.length \>= 5 && deliveryArchitecture.total\_team\_size\_fte \< 15\) alignmentScore \+= 1;

// Theme 5: Founder Transition Imperative  
let founderTransitionScore \= 0;  
if (deliveryArchitecture.founder\_time\_allocation \=== "Mostly client work" && economicFoundation.annual\_agi \> 1500000\) founderTransitionScore \+= 4;  
if (deliveryArchitecture.founder\_time\_allocation \=== "Mix delivery-ops" && economicFoundation.annual\_agi \> 2500000\) founderTransitionScore \+= 2;  
if (revenueModel.concentration\_top\_5\_percent \> 60 && deliveryArchitecture.founder\_time\_allocation \=== "Mostly client work") founderTransitionScore \+= 2;  
if (deliveryArchitecture.total\_team\_size\_fte \> 20 && deliveryArchitecture.founder\_time\_allocation \=== "Mostly client work") founderTransitionScore \+= 2;  
if (\!deliveryArchitecture.leadership\_roles\_present.includes("COO") && economicFoundation.annual\_agi \> 2000000\) founderTransitionScore \+= 1;

// Determine top 3 themes  
const themeScores \= {  
  growth\_treadmill: growthTreadmillScore,  
  cash\_margin\_disconnect: cashMarginScore,  
  concentration\_dependency: concentrationScore,  
  service\_structure\_alignment: alignmentScore,  
  founder\_transition\_imperative: founderTransitionScore  
};

// Sort by score and select top 3 that meet thresholds  
const thresholds \= {  
  growth\_treadmill: 5,  
  cash\_margin\_disconnect: 4,  
  concentration\_dependency: 5,  
  service\_structure\_alignment: 3,  
  founder\_transition\_imperative: 4  
};

let selectedThemes \= Object.entries(themeScores)  
  .filter((\[theme, score\]) \=\> score \>= thresholds\[theme\])  
  .sort((a, b) \=\> b\[1\] \- a\[1\])  
  .slice(0, 3\)  
  .map((\[theme\]) \=\> theme);

// Fallback if fewer than 3 themes qualify  
if (selectedThemes.length \< 3\) {  
  selectedThemes \= Object.entries(themeScores)  
    .sort((a, b) \=\> b\[1\] \- a\[1\])  
    .slice(0, 3\)  
    .map((\[theme\]) \=\> theme);  
}

