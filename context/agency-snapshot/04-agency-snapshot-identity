Table: agency_identity (Main Storage)
Sql
CREATE TABLE agency_identity (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_id UUID NOT NULL REFERENCES auth.users(id),
  
  -- Service Scope
  primary_services UUID[] REFERENCES services(id), -- Array of service IDs
  primary_services_other TEXT, -- If "Other" selected
  secondary_services UUID[], -- Array of service IDs
  secondary_services_other TEXT, -- If "Other" selected
  
  -- Market Focus
  primary_industries UUID[] REFERENCES industries(id), -- Array of industry IDs, max 5
  primary_industries_other TEXT, -- If "Other" selected
  geographic_footprint TEXT, -- 'local', 'regional', 'national', 'international'
  
  -- Pricing Model
  pricing_models TEXT[], -- Array of pricing approach strings
  
  -- Positioning
  website_url TEXT,
  website_scraped_content JSONB, -- Stores FireCrawl results
  positioning_context TEXT, -- Manual fallback/additional context
  
  -- Synthesis Results
  identity_profile JSONB, -- Stores structured synthesis + narrative
  
  -- Metadata
  completed_at TIMESTAMP WITH TIME ZONE,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Index for user lookups
CREATE INDEX idx_agency_identity_user_id ON agency_identity(user_id);
