Recommended UI Implementation
Button Component State:
jsx
const SaveButton = ({ tabName, hasChanges, isProcessing, onSave }) => {
  const getButtonState = () => {
    if (isProcessing) return 'processing';
    if (justSaved) return 'success'; // tracks recent save
    if (hasChanges) return 'edited';
    if (hasSavedData) return 'saved';
    return 'initial';
  };
  
  const state = getButtonState();
  
  const config = {
    initial: {
      text: `Save ${tabName} Data`,
      color: 'blue',
      disabled: !isValid,
      icon: null
    },
    saved: {
      text: 'Saved',
      color: 'gray',
      disabled: true,
      icon: <CheckIcon />
    },
    edited: {
      text: `Update ${tabName} Data`,
      color: 'amber',
      disabled: false,
      icon: null
    },
    processing: {
      text: 'Processing...',
      color: 'blue',
      disabled: true,
      icon: <SpinnerIcon />
    },
    success: {
      text: '✓ Saved',
      color: 'green',
      disabled: true,
      icon: <CheckIcon />
    }
  };
  
  return (
    <button 
      className={`btn-${config[state].color}`}
      disabled={config[state].disabled}
      onClick={onSave}
    >
      {config[state].icon}
      {config[state].text}
    </button>
  );
};
