## 2. New Reference Table — `gm_cross_sections`

### Table Definition

```sql
CREATE TABLE public.gm_cross_sections (
  cross_section_id       text        NOT NULL,
  cross_section_label    text        NOT NULL,
  cross_section_order    integer     NOT NULL,
  stage_fit_id           text        NOT NULL,
  three_p_id             text        NOT NULL,
  definition             text        NULL,
  is_active              boolean     NOT NULL DEFAULT true,
  created_at             timestamptz NOT NULL DEFAULT now(),
  updated_at             timestamptz NULL,

  CONSTRAINT gm_cross_sections_pkey
    PRIMARY KEY (cross_section_id),

  CONSTRAINT gm_cross_sections_stage_fit_fkey
    FOREIGN KEY (stage_fit_id)
    REFERENCES gm_stage_fit_factors (stage_fit_id)
    ON UPDATE CASCADE ON DELETE RESTRICT,

  CONSTRAINT gm_cross_sections_three_p_fkey
    FOREIGN KEY (three_p_id)
    REFERENCES gm_3p_weights (three_p_id)
    ON UPDATE CASCADE ON DELETE RESTRICT
);

CREATE UNIQUE INDEX IF NOT EXISTS gm_cross_sections_order_uq
  ON public.gm_cross_sections USING btree (cross_section_order);

CREATE UNIQUE INDEX IF NOT EXISTS gm_cross_sections_inputs_uq
  ON public.gm_cross_sections USING btree (stage_fit_id, three_p_id);

CREATE INDEX IF NOT EXISTS gm_cross_sections_is_active_idx
  ON public.gm_cross_sections USING btree (is_active);
```

